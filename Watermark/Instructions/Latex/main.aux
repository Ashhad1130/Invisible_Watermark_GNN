\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Cross-configuration visual comparison (img\_0016).} Each row shows one configuration: no-watermark reference (left), clean watermarked image (centre), and watermarked image after the hardest available attack for that configuration (right), with the resulting AUC over 50 images. The no-watermark and watermarked images are visually indistinguishable across all configurations. On the rotation $45^\circ $ attack (rows 2--4), AUC improves from 0.894 (Multi-Ring) to 0.986 (MR-AllChan), illustrating the gain from all-channel embedding on geometric attacks. Note: Baseline and Optimized output images were only saved for jpeg\_50 and rotation\_45 respectively; all other attacks are covered by Multi-Ring and MR-AllChan.}}{19}{figure.caption.15}\protected@file@percent }
\newlabel{fig:config_comparison}{{5}{19}{\textbf {Cross-configuration visual comparison (img\_0016).} Each row shows one configuration: no-watermark reference (left), clean watermarked image (centre), and watermarked image after the hardest available attack for that configuration (right), with the resulting AUC over 50 images. The no-watermark and watermarked images are visually indistinguishable across all configurations. On the rotation $45^\circ $ attack (rows 2--4), AUC improves from 0.894 (Multi-Ring) to 0.986 (MR-AllChan), illustrating the gain from all-channel embedding on geometric attacks. Note: Baseline and Optimized output images were only saved for jpeg\_50 and rotation\_45 respectively; all other attacks are covered by Multi-Ring and MR-AllChan}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Photometric attacks --- all four configurations on img\_0018.} Rows: Baseline ($N{=}50$, 3\,ch, circle) / Optimized ($N{=}100$, 3\,ch, circle) / Multi-Ring ($N{=}100$, 3\,ch, dual-band) / MR-AllChan ($N{=}100$, 4\,ch, dual-band). Columns: clean watermark then 8 photometric attacks. Numbers below each thumbnail are AUC values from the full 50-image evaluation. All configurations achieve AUC $\geq 0.931$ across all photometric conditions; MR-AllChan is consistently best under additive noise.}}{20}{figure.caption.16}\protected@file@percent }
\newlabel{fig:gallery_photometric}{{6}{20}{\textbf {Photometric attacks --- all four configurations on img\_0018.} Rows: Baseline ($N{=}50$, 3\,ch, circle) / Optimized ($N{=}100$, 3\,ch, circle) / Multi-Ring ($N{=}100$, 3\,ch, dual-band) / MR-AllChan ($N{=}100$, 4\,ch, dual-band). Columns: clean watermark then 8 photometric attacks. Numbers below each thumbnail are AUC values from the full 50-image evaluation. All configurations achieve AUC $\geq 0.931$ across all photometric conditions; MR-AllChan is consistently best under additive noise}{figure.caption.16}{}}
